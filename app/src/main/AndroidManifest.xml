        <activity
            android:name=".view.event.MapClickEventActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_event_click_map"
            android:label="@string/igm_name_event_click_map">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_event" />
        </activity>

        <activity
            android:name=".view.event.ShapeClickEventActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
