            android:name=".view.shape.IgmCircleActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_circle"
            android:label="@string/igm_name_circle">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_shapes" />
        </activity>

        <activity
            android:name=".view.shape.GlobalZIndexActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
