            android:description="@string/igm_description_map_option_padding">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_map_option" />
        </activity>

        <activity
            android:name=".view.option.MapGestureActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_map_option_gesture">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_map_option" />
        </activity>

        <activity
            android:name=".view.option.MapControllerActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_map_option_controller">
