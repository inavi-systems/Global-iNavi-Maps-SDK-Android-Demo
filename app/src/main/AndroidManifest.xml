<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/orbismap_app_icon"
        android:label="@string/igm_app_name"
        android:roundIcon="@mipmap/orbismap_app_icon"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".view.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.inavi.global.mapsdk.Appkey"
            android:value="YOUR_APP_KEY"/>

        <!-- Map -->
        <activity
            android:name=".view.map.IgmMapFragmentActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_map_fragment"
            android:label="@string/igm_name_map_fragment">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_map" />
        </activity>

        <activity
            android:name=".view.map.IgmMapViewActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_map_view"
            android:label="@string/igm_name_map_view">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_map" />
        </activity>

        <!-- Shape -->
        <activity
            android:name=".view.shape.IgmMarkerActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_marker"
            android:label="@string/igm_name_marker">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_shapes" />
        </activity>

        <activity
            android:name=".view.shape.IgmMarkerOverlapActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_marker_overlap"
            android:label="@string/igm_name_marker_overlap">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_shapes" />
        </activity>

        <activity
            android:name=".view.shape.IgmInfoWindowActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_info_window"
            android:label="@string/igm_name_info_window">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_shapes" />
        </activity>

        <activity
            android:name=".view.shape.IgmPolygonActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:description="@string/igm_description_polygon"
            android:label="@string/igm_name_polygon">
            <meta-data
                android:name="@string/igm_category"
                android:value="@string/igm_category_shapes" />
        </activity>

        <activity
            android:name=".view.shape.IgmPolylineActivity"
